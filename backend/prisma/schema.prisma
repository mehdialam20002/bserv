generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  imageUrl    String?   @map("image_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  machines    Machine[]

  @@map("categories")
}

model Machine {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(255)
  slug               String    @unique @db.VarChar(255)
  brand              String    @db.VarChar(100)
  categoryId         Int?      @map("category_id")
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description        String?
  features           String[]
  specifications     Json?
  price              Decimal?  @db.Decimal(12, 2)
  rentPriceMonthly   Decimal?  @map("rent_price_monthly") @db.Decimal(10, 2)
  rentPriceYearly    Decimal?  @map("rent_price_yearly") @db.Decimal(12, 2)
  isAvailableForSale Boolean   @default(true) @map("is_available_for_sale")
  isAvailableForRent Boolean   @default(true) @map("is_available_for_rent")
  condition          String    @default("new") @db.VarChar(50)
  images             String[]
  thumbnail          String?
  rating             Decimal   @default(0) @db.Decimal(2, 1)
  reviewCount        Int       @default(0) @map("review_count")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  reviews   Review[]
  inquiries Inquiry[]
  orders    Order[]

  @@map("machines")
}

model Inquiry {
  id          Int      @id @default(autoincrement())
  machineId   Int?     @map("machine_id")
  machine     Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)
  name        String   @db.VarChar(100)
  email       String   @db.VarChar(150)
  phone       String   @db.VarChar(20)
  company     String?  @db.VarChar(150)
  message     String?
  inquiryType String   @map("inquiry_type") @db.VarChar(20)
  status      String   @default("pending") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("inquiries")
}

model Order {
  id                 Int      @id @default(autoincrement())
  orderNumber        String   @unique @map("order_number") @db.VarChar(50)
  machineId          Int?     @map("machine_id")
  machine            Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)
  customerName       String   @map("customer_name") @db.VarChar(100)
  customerEmail      String   @map("customer_email") @db.VarChar(150)
  customerPhone      String   @map("customer_phone") @db.VarChar(20)
  customerCompany    String?  @map("customer_company") @db.VarChar(150)
  customerAddress    String   @map("customer_address")
  orderType          String   @map("order_type") @db.VarChar(10)
  rentDurationMonths Int?     @map("rent_duration_months")
  totalAmount        Decimal  @map("total_amount") @db.Decimal(12, 2)
  status             String   @default("pending") @db.VarChar(20)
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("orders")
}

model Review {
  id        Int      @id @default(autoincrement())
  machineId Int      @map("machine_id")
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(150)
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(150)
  phone     String?  @db.VarChar(20)
  subject   String?  @db.VarChar(200)
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}
