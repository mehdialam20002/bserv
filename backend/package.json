{
  "name": "bserv-backend",
  "version": "1.0.0",
  "description": "Photocopier Machine Business Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:push": "npx prisma db push",
    "db:seed": "node src/seeds/seed.js",
    "db:studio": "npx prisma studio",
    "db:setup": "npx prisma db push --skip-generate && node src/seeds/seed.js",
    "prisma:generate": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
